{{!
    @template report_feedback_tracker/termselector

    Sub-template for displaying a selector for academic years.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * none

    Example context (json):
    {
    }

}}
<div>
    {{#str}} term, report_feedback_tracker {{/str}}:
    {{#termoptions}}
        {{^code}}
            <strong>{{title}}</strong>
        {{/code}}
        {{#code}}
            <a href="{{{ config.wwwroot }}}/report/feedback_tracker/site.php?year={{selectedyear}}&term={{code}}">{{title}}</a>
        {{/code}}
    {{/termoptions}}
</div>
