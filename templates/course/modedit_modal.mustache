{{!
    @template report_feedback_tracker/generalfeedback_modal

    Template for displaying a modal dialog to edit general feedback.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * none

    Example context (json):
    {
        "title": "A title",
        "generalfeedbacklabel": "General Feedback:",
        "generalfeedback": "This is good.",
        "gfurllabel": "NASA",
        "gfurl": "www.nasa.gov"
    }

}}
<div class="modal-header">
    <h4>{{title}}</h4>
</div>
<div class="modal-body">
    <form id="modalForm">
        <input type="hidden" id="js-gradeitemid" value="{{gradeitemid}}">
        <input type="hidden" id="js-partid" value="{{partid}}">

        <div class="form-group">
            <label for="contact">Contact</label>
            <input type="text" class="form-control" id="js-contact" name="contact" value="{{{contact}}}">
            <div class="form-check">
                <label class="form-check-label">
                    <input type="checkbox" class="form-check-input" value=""  id="js-hidden" name="hidden" {{#hidden}}checked{{/hidden}}>Hidden from student report
                </label>
            </div>

            <label for="method">Method</label>
            <input type="text" class="form-control" id="js-method" name="method" value="{{{method}}}">

            <label for="generalfeedback">Generalfeedback</label>
            <textarea class="form-control" id="js-generalfeedback" name="generalfeedback" rows= "5">{{{generalfeedback}}}</textarea>

            <label for="feedbackduedate">Feedbackduedate</label>
            <input type="date" class="form-control" id="feedbackduedate" name="feedbackduedate" value="{{{formatteddate}}}">
            <input type="hidden" id="js-formatteddate" value="{{formatteddate}}">

            <label for="assessmenttype">Assessmenttype</label>
            <input type="text" class="form-control" id="js-assessmenttype" name="assessmenttype" value="{{{assessmenttype}}}">

        </div>
    </form>
</div>
